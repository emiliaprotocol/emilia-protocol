{
  "compilerOptions": {
    "allowJs": true, "checkJs": true, "noEmit": true, "strict": false,
    "target": "es2022", "module": "esnext", "moduleResolution": "bundler",
    "skipLibCheck": true, "noImplicitAny": false, "baseUrl": ".",
    "paths": { "@/*": ["./*"] }
  },
  "include": [
    "scripts/**/*.js", "scripts/**/*.mjs",
    "conformance/**/*.js", "conformance/**/*.mjs",
    "mcp-server/**/*.js", "mcp-server/**/*.mjs",
    "examples/**/*.js", "examples/**/*.mjs",
    "packages/mcp-guard/**/*.js", "packages/require-receipt/**/*.js",
    "packages/langchain/**/*.js", "packages/openai-guard/**/*.js",
    "packages/mobile/**/*.js"
  ],
  "exclude": ["**/*.test.js", "**/*.test.mjs", "**/*.selftest.mjs", "**/node_modules/**"]
}
