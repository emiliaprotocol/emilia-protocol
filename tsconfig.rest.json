{
  "compilerOptions": {
    "allowJs": true, "checkJs": true, "noEmit": true, "strict": false, "strictNullChecks": true,
    "target": "es2022", "module": "esnext", "moduleResolution": "bundler",
    "skipLibCheck": true, "noImplicitAny": true, "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@emilia-protocol/fire-drill": ["./packages/fire-drill/index.js"],
      "@emilia-protocol/fire-drill/*": ["./packages/fire-drill/*"]
    }
  },
  "include": [
    "actions/**/*",
    "apps/gate-service/src/**/*",
    "attestation/**/*",
    "bench/**/*",
    "caid/**/*",
    "cli/bin/**/*",
    "cli/lib/**/*",
    "conformance/**/*",
    "create-ep-app/index.js",
    "eslint-rules/**/*",
    "examples/**/*",
    "formal/**/*",
    "fuzz/**/*",
    "integrations/**/*",
    "load-tests/**/*",
    "mcp-server/**/*",
    "ml/**/*",
    "mobile/**/*",
    "packages/attest/index.js",
    "packages/crash-test/crash-test.mjs",
    "packages/ep-verify/cli.mjs",
    "packages/fire-drill/cli.mjs",
    "packages/fire-drill/corpus.js",
    "packages/fire-drill/corpus.mjs",
    "packages/fire-drill/index.js",
    "packages/fire-drill/ingest.mjs",
    "packages/fire-drill/registry-corpus.js",
    "packages/fire-drill-mcp/index.js",
    "packages/gate/**/*.mjs",
    "packages/gate/**/*.d.ts",
    "packages/issue/cli.js",
    "packages/issue/index.js",
    "packages/issue/strict-json.js",
    "packages/langchain/**/*.js",
    "packages/langchain/**/*.mjs",
    "packages/mcp-guard/**/*.js",
    "packages/mobile/**/*.js",
    "packages/openai-agents/index.js",
    "packages/openai-guard/**/*.js",
    "packages/openai-guard/**/*.mjs",
    "packages/require-receipt/**/*.js",
    "packages/require-receipt/**/*.mjs",
    "packages/scan/cli.mjs",
    "packages/scan/codemod.mjs",
    "packages/scan/index.js",
    "packages/scan/risk-packs.js",
    "packages/verify/**/*.d.ts",
    "receipt-required-pr-kit/**/*",
    "scripts/**/*",
    "witness/**/*"
  ],
  "exclude": [
    "**/*.test.js",
    "**/*.test.mjs",
    "**/*.spec.js",
    "**/*.spec.mjs",
    "**/*.selftest.mjs",
    "**/*.node-test.mjs",
    "**/test/**",
    "**/tests/**",
    "**/__tests__/**",
    "**/dist/**",
    "**/node_modules/**"
  ]
}
