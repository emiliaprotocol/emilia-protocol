{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "strictNullChecks": true,
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "noImplicitAny": false,
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ]
    }
  },
  "include": [
    "lib/**/*.js",
    "lib/**/*.mjs",
    "lib/**/*.ts",
    "lib/**/*.mts"
  ],
  "exclude": [
    "**/*.test.js",
    "**/*.test.mjs",
    "lib/dist/**",
    "**/node_modules/**",
    "**/*.test.ts",
    "**/*.test.mts"
  ]
}
