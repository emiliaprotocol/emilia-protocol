{
  "protocol": "emilia-protocol",
  "version": "1.1",
  "protocol_version": "EP-CORE-v1.0",
  "trust_profile_url": "https://emiliaprotocol.ai/api/trust/profile/{entity_id}?view=capability",
  "_trust_profile_url_note": "Public capability projection: boolean only (capability present or not — no score, counts, volume, or timeline). The full profile at /api/trust/profile/{entity_id} requires entity authentication and is self-scoped to the authenticated entity.",
  "trust_evaluate_url": "https://emiliaprotocol.ai/api/trust/evaluate",
  "_trust_evaluate_url_note": "Requires an entity API key — authenticated trust evaluation. Public callers should verify a receipt (/verify) or read the capability projection above.",
  "receipt_submit_url": "https://emiliaprotocol.ai/api/receipts/submit",
  "receipt_confirm_url": "https://emiliaprotocol.ai/api/receipts/confirm",
  "agent_actions_url": "https://emiliaprotocol.ai/.well-known/agent-actions.json",
  "agent_action_control_url": "https://www.emiliaprotocol.ai/.well-known/agent-action-control.json",
  "dispute_file_url": "https://emiliaprotocol.ai/api/disputes/file",
  "dispute_report_url": "https://emiliaprotocol.ai/api/disputes/report",
  "appeal_page_url": "https://emiliaprotocol.ai/appeal",
  "trust_profile_url_legacy": "https://emiliaprotocol.ai/api/score/{entity_id}",
  "_trust_profile_url_legacy_note": "DEPRECATED: Returns legacy compat_score on 0-100 scale. Use trust_profile_url for trust decisions. See PROTOCOL-STANDARD.md §20.",
  "spec_url": "https://datatracker.ietf.org/doc/draft-schrock-ep-authorization-receipts/",
  "conformance_url": "https://github.com/emiliaprotocol/emilia-protocol/tree/main/conformance",
  "mcp_package": "@emilia-protocol/mcp-server",
  "supported_policies": [
    "strict",
    "standard",
    "permissive",
    "discovery",
    "github_private_repo_safe_v1",
    "npm_buildtime_safe_v1",
    "browser_extension_safe_v1",
    "mcp_server_safe_v1"
  ],
  "context_keys": [
    "task_type",
    "category",
    "geo",
    "modality",
    "value_band",
    "risk_class"
  ],
  "provenance_tiers": [
    "self_attested",
    "identified_signed",
    "bilateral",
    "platform_originated",
    "carrier_verified",
    "oracle_verified"
  ],
  "extensions": {
    "software_trust": {
      "version": "0.1-draft",
      "supported_hosts": [
        "github",
        "npm",
        "chrome",
        "mcp",
        "shopify"
      ],
      "entity_types": [
        "github_app",
        "github_action",
        "mcp_server",
        "npm_package",
        "chrome_extension",
        "shopify_app",
        "marketplace_plugin",
        "agent_tool"
      ],
      "spec_url": "https://github.com/emiliaprotocol/emilia-protocol/blob/main/docs/EP-SX-SOFTWARE-TRUST.md"
    }
  },
  "constitutional_principle": "Trust must never be more powerful than appeal.",
  "core_policies": [
    "strict",
    "standard",
    "permissive",
    "discovery"
  ],
  "software_policies": [
    "github_private_repo_safe_v1",
    "npm_buildtime_safe_v1",
    "browser_extension_safe_v1",
    "mcp_server_safe_v1"
  ],
  "signing_keys": {
    "current": {
      "kid": "ep-signing-key-1",
      "algorithm": "Ed25519",
      "public_key_base64": "RUNTIME_GENERATED",
      "status": "active",
      "created_at": "2025-01-01T00:00:00Z",
      "note": "In production, this key is derived from EP_COMMIT_SIGNING_KEY env var. The public key shown here is a placeholder — use the /api/commit/keys endpoint for the live key set."
    },
    "rotation_policy": {
      "rotation_interval_days": 90,
      "overlap_period_days": 14,
      "revocation_mechanism": "Key removed from active set; old signatures remain verifiable via archived keys"
    },
    "discovery_endpoint": "/api/commit/keys"
  }
}
