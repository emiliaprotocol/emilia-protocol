# EMILIA Protocol — Code Ownership
#
# Current governance is single-maintainer. Adding a genuinely independent
# second owner/reviewer is an open governance milestone; no completed
# transition is claimed. Until then, every path assigns review responsibility
# to the current maintainer; administrator enforcement remains a separate
# governance milestone.
#
# Format: pattern  @owner

# Default: all files require maintainer review
*                           @futureenterprises

# Core protocol — trust scoring, write path, state machines
lib/scoring*.js             @futureenterprises
lib/protocol-write.js       @futureenterprises
lib/write-guard.ts          @futureenterprises
lib/canonical-evaluator.ts  @futureenterprises
lib/signoff/                @futureenterprises
lib/handshake/              @futureenterprises

# Formal verification models
formal/                     @futureenterprises

# Database schema — migrations require extra scrutiny
supabase/migrations/        @futureenterprises

# CI/CD — pipeline changes require maintainer review
.github/                    @futureenterprises
