{
  "@version": "EP-RECEIPT-REQUIRED-BINDINGS-v1",
  "registry_id": "ep:receipt-required:bindings:v1",
  "description": "Data-only carrier profiles for transporting a Receipt Required challenge and an EMILIA proof binding without adding protocol-specific authorization logic.",
  "artifact_boundary": "A profile maps fields and proof slots only. Every foreign artifact must verify under its native rules before its CAID or action hash is relied on. A mapped CAID is not authorization, adoption, or execution proof.",
  "profiles": [
    {
      "profile_id": "ep:receipt-required:binding:http:v1",
      "protocol_id": "http",
      "protocol_version": "HTTP with Receipt Required v0.2",
      "implementation_status": "experimental_reference",
      "match_selector": {
        "carrier": "http_response",
        "discriminator_path": "/status",
        "discriminator_value": 428
      },
      "challenge_carrier": {
        "kind": "http_problem_response",
        "location": "Receipt-Required header and problem body",
        "content_type": "application/problem+json",
        "refusal_code": 428
      },
      "proof_carrier": {
        "kind": "http_request_header",
        "location": "X-EMILIA-Receipt",
        "content_type": "application/ep-receipt+json"
      },
      "caid_extraction": {
        "caid_path": "/request/headers/X-EMILIA-Receipt/binding/caid",
        "action_hash_path": "/request/headers/X-EMILIA-Receipt/binding/action_hash"
      },
      "required_field_mapping": [
        {
          "action_field": "action_type",
          "source_path": "/request/body/action_type"
        },
        { "action_field": "amount", "source_path": "/request/body/amount" },
        { "action_field": "currency", "source_path": "/request/body/currency" },
        {
          "action_field": "beneficiary_account",
          "source_path": "/request/body/beneficiary_account"
        },
        {
          "action_field": "payment_instruction_id",
          "source_path": "/request/body/payment_instruction_id"
        }
      ],
      "conformance_vector_refs": [
        "accept_same_action",
        "reject_caid_mismatch",
        "reject_action_hash_mismatch",
        "reject_missing_protocol_binding"
      ],
      "claim_boundary": "The repository contains an experimental HTTP carrier and gateway reference. Native wire-format interoperability and independent deployment verification are not claimed."
    },
