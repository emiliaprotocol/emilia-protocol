# CI resilience: transient npm-registry network errors (ECONNRESET, ETIMEDOUT,
# 5xx) must RETRY, not fail a job. A single ECONNRESET during `npm ci` once
# red-flagged the release-blocking `schema-security / schema-contract` gate
# (run 28566985233) even though the schema was fine — the install never reached
# the check. These bump npm's NATIVE fetch-retry so every `npm ci` across all
# workflows self-heals from a registry blip, with zero new CI dependencies.
# Harmless locally: retries only engage on an actual network failure.
fetch-retries=5
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000
fetch-timeout=600000

# Supply-chain: refuse to resolve dependency versions published less than 7 days
# ago. A newly-published version is the compromise window (hijacked maintainer,
# malicious release); waiting out a week lets the ecosystem catch it first. This
# is the correct posture for a supply-chain-trust product. Also stops the
# dependabot auto-merge path from pulling day-0 releases. Requires npm >= 11.10;
# older npm ignores the unknown key harmlessly.
min-release-age=7
