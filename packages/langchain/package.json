{
  "name": "@emilia-protocol/langchain",
  "version": "0.3.1",
  "description": "Guard LangChain.js tools with EMILIA Protocol — require an offline-verifiable authorization receipt (EP-RECEIPT-v1) before an irreversible tool runs: missing -> refused, valid -> runs, replay -> refused, forged -> refused (RR-1). The approval becomes portable evidence an auditor can check without trusting the operator.",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "index.js",
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pretest": "npm run build",
    "test": "node --test"
  },
  "keywords": [
    "langchain",
    "langchainjs",
    "ai-agent",
    "authorization",
    "human-in-the-loop",
    "guardrails",
    "emilia-protocol",
    "agent-safety"
  ],
  "dependencies": {
    "@emilia-protocol/require-receipt": "^0.6.0"
  },
  "peerDependencies": {
    "@langchain/core": ">=0.1.0"
  },
  "peerDependenciesMeta": {
    "@langchain/core": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emiliaprotocol/emilia-protocol.git",
    "directory": "packages/langchain"
  },
  "homepage": "https://www.emiliaprotocol.ai/agent-guard",
  "publishConfig": {
    "access": "public"
  }
}
