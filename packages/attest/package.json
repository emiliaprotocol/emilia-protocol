{
  "name": "@emilia-protocol/attest",
  "version": "0.2.0",
  "description": "Bind relying-party-pinned identity bytes and subject to a work-product hash in a signed EP receipt; no identity, authority, or execution overclaim.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "index.js",
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@emilia-protocol/issue": "^0.4.0",
    "@emilia-protocol/verify": "^3.10.0"
  },
  "keywords": [
    "emilia-protocol",
    "identity",
    "attestation",
    "receipts",
    "ed25519",
    "sha256",
    "offline-verification",
    "agent"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/emiliaprotocol/emilia-protocol.git",
    "directory": "packages/attest"
  },
  "homepage": "https://emiliaprotocol.ai",
  "bugs": {
    "url": "https://github.com/emiliaprotocol/emilia-protocol/issues"
  },
  "author": "EMILIA Protocol, Inc.",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pretest": "npm run build",
    "test": "node --test test.js"
  },
  "publishConfig": {
    "access": "public"
  }
}
