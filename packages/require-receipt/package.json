{
  "name": "@emilia-protocol/require-receipt",
  "version": "0.7.0",
  "description": "Demand a verifiable EMILIA authorization receipt for any irreversible agent action. Emits Receipt Required challenges (428, with legacy 402 compatibility) and tells the agent exactly what to bring.",
  "type": "module",
  "main": "index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./dist/index.d.ts"
    },
    "./strict-json": {
      "import": "./strict-json.js",
      "types": "./dist/strict-json.d.ts"
    },
    "./edge": {
      "import": "./dist/edge.js",
      "types": "./dist/edge.d.ts"
    },
    "./acquisition": {
      "import": "./dist/acquisition.js",
      "types": "./dist/acquisition.d.ts"
    }
  },
  "files": [
    "index.js",
    "index.d.ts",
    "gate.js",
    "gate.d.ts",
    "strict-json.js",
    "strict-json.d.ts",
    "jws.js",
    "jws.d.ts",
    "dist/",
    "src/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pretest": "npm run build",
    "test": "node --test",
    "build:drop-in": "node build-drop-in.mjs"
  },
  "devDependencies": {
    "jose": "^6.2.3"
  },
  "license": "Apache-2.0",
  "keywords": [
    "emilia-protocol",
    "ai-agent",
    "trust-receipt",
    "agent-authorization",
    "agent-accountability",
    "receipt-required",
    "428",
    "402",
    "agent-commerce",
    "verifiable-credential",
    "a2a"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emiliaprotocol/emilia-protocol.git",
    "directory": "packages/require-receipt"
  },
  "homepage": "https://www.emiliaprotocol.ai/agent-guard",
  "publishConfig": {
    "access": "public"
  }
}
