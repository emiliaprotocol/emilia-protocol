{
  "compilerOptions": {
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "rootDir": "src",
    "outDir": "dist",
    "noEmitOnError": true
  },
  "include": [
    "src/strict-json.ts",
    "src/time-attestation.ts",
    "src/evidence-record.ts",
    "src/authority-proof.ts",
    "src/consistency.ts",
    "src/currency.ts",
    "src/revocation.ts",
    "src/quorum.ts",
    "src/witness.ts",
    "src/effect-predicates.ts",
    "src/initiator-attestation.ts",
    "src/surface-binding.ts",
    "src/pq-hybrid.ts",
    "src/timestamp-proof.ts",
    "src/consumption-proof.ts",
    "src/web.ts",
    "src/provenance.ts",
    "src/federation.ts",
    "src/resolution.ts",
    "src/consent-grant.ts",
    "src/document-action-binding.ts",
    "src/outcome-binding.ts",
    "src/reliance.ts",
    "src/reliance-profile-registry.ts",
    "src/reliance-agreement.ts",
    "src/reliance-gap.ts",
    "src/agentroa.ts",
    "src/orprg.ts",
    "src/platform-attestation.ts",
    "src/evidence-chain.ts",
    "src/index.ts",
    "src/cli.ts"
  ]
}
