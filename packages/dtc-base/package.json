{
  "name": "@emilia-protocol/dtc-base",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Experimental DTC Base settlement profile for exact, consequence-bound machine actions",
  "license": "Apache-2.0",
  "exports": {
    ".": {
      "types": "./dist/lib/receipt-program-bridge.d.ts",
      "import": "./dist/lib/receipt-program-bridge.js"
    }
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "compile": "hardhat compile",
    "demo": "npm run build && node dist/scripts/demo.js",
    "deploy:base-sepolia": "npm run build && HARDHAT_NETWORK=baseSepolia node dist/scripts/deploy.js",
    "test": "npm run test:functional && npm run test:hostile && npm run test:integration",
    "test:functional": "hardhat test test/DTCBaseSettlement.test.cjs",
    "test:hostile": "hardhat test test/DTCBaseSettlement.hostile.test.cjs test/DTCBaseSettlement.audit-regressions.test.cjs",
    "test:integration": "npm run build && hardhat test test/DTCReceiptProgram.integration.test.cjs test/ReceiptProgramBridge.characterization.test.cjs",
    "coverage": "npm run build && hardhat coverage",
    "lint": "npm run lint:sol",
    "lint:sol": "solhint contracts/DTCBaseSettlement.sol contracts/interfaces/IDTCBaseSettlement.sol",
    "audit:prod": "npm audit --omit=dev --audit-level=low",
    "audit:toolchain": "node scripts/audit-toolchain.mjs",
    "policy:verify": "node scripts/verify-package-policy.mjs",
    "formal:verify": "bash scripts/run-formal.sh",
    "formal:refresh": "bash scripts/run-formal.sh --write",
    "artifacts:verify": "node scripts/verify-artifact-manifest.mjs",
    "artifacts:refresh": "node scripts/verify-artifact-manifest.mjs --write",
    "evidence:verify": "npm run formal:verify && npm run artifacts:verify",
    "evidence:refresh": "npm run formal:refresh && npm run artifacts:refresh",
    "verify": "npm run policy:verify && npm run typecheck && npm run compile && npm test && npm run lint && npm run audit:prod && npm run audit:toolchain && npm run evidence:verify"
  },
  "dependencies": {
    "@openzeppelin/contracts": "5.4.0",
    "ethers": "6.17.0"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@nomicfoundation/hardhat-chai-matchers": "2.1.2",
    "@nomicfoundation/hardhat-ethers": "3.1.3",
    "@nomicfoundation/hardhat-network-helpers": "1.1.2",
    "hardhat": "2.28.5",
    "chai": "4.5.0",
    "solhint": "6.2.3",
    "solidity-coverage": "0.8.17",
    "typescript": "5.9.3"
  }
}
