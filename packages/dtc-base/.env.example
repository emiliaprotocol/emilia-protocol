# Base Sepolia only. This private package deliberately has no Base mainnet target.
BASE_SEPOLIA_RPC_URL=
DEPLOYER_PRIVATE_KEY=

# Required acknowledgement for any non-local deployment.
DTC_DEPLOY_ACK=I_UNDERSTAND_THIS_IS_PRIVATE_UNAUDITED_CODE

# Role owners. Do not use development keys.
DTC_ADMIN_ADDRESS=
DTC_AUTHORIZATION_SIGNER_ADDRESS=

# Optional initial provider binding. Set both or neither.
DTC_INITIAL_MERCHANT_ADDRESS=
DTC_INITIAL_PROVIDER_SIGNER_ADDRESS=
