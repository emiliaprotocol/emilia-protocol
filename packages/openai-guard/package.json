{
  "name": "@emilia-protocol/openai-guard",
  "version": "0.4.0",
  "description": "Guard OpenAI-compatible tool calls (OpenAI, xAI Grok, Together, …) with EMILIA Protocol — block irreversible agent actions until a named human signs off.",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./dist/index.d.ts"
    },
    "./receipt": {
      "import": "./receipt.js",
      "types": "./dist/receipt.d.ts"
    }
  },
  "files": ["index.js", "receipt.js", "dist/", "src/", "tsconfig.json", "README.md", "LICENSE"],
  "license": "Apache-2.0",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pretest": "npm run build",
    "test": "node --test"
  },
  "dependencies": {
    "@emilia-protocol/require-receipt": "^0.6.0"
  },
  "peerDependencies": {
    "@emilia-protocol/verify": "^3.10.0"
  },
  "peerDependenciesMeta": {
    "@emilia-protocol/verify": { "optional": true }
  },
  "keywords": [
    "openai",
    "grok",
    "xai",
    "tool-calling",
    "function-calling",
    "ai-agent",
    "authorization",
    "human-in-the-loop",
    "guardrails",
    "emilia-protocol",
    "agent-safety"
  ],
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emiliaprotocol/emilia-protocol.git",
    "directory": "packages/openai-guard"
  },
  "homepage": "https://www.emiliaprotocol.ai/agent-guard",
  "publishConfig": {
    "access": "public"
  }
}
