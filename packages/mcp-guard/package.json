{
  "name": "@emilia-protocol/mcp-guard",
  "version": "0.4.0",
  "description": "Fail-closed MCP receipt middleware with exact-action binding, one-time consumption, strict receipt parsing, and escalation-only treatment of untrusted tool metadata.",
  "type": "module",
  "main": "index.js",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "index.js",
    "dist/",
    "src/",
    "tsconfig.json",
    "README.md",
    "LICENSE"
  ],
  "license": "Apache-2.0",
  "keywords": [
    "emilia-protocol",
    "mcp",
    "model-context-protocol",
    "ai-agent",
    "tool-calling",
    "irreversible-actions",
    "human-in-the-loop",
    "class-a-signoff",
    "ep-receipt-v1",
    "provenance",
    "402",
    "agent-accountability"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pretest": "npm run build",
    "test": "cd ../.. && npx vitest run tests/mcp-guard-boundary.test.ts"
  },
  "peerDependencies": {
    "@emilia-protocol/require-receipt": "^0.6.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emiliaprotocol/emilia-protocol.git",
    "directory": "packages/mcp-guard"
  },
  "homepage": "https://www.emiliaprotocol.ai/agent-guard",
  "publishConfig": {
    "access": "public"
  }
}
