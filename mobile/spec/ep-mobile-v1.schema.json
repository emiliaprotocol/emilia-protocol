{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emiliaprotocol.ai/schemas/ep-mobile-v1.schema.json",
  "title": "EMILIA Mobile v1 artifacts",
  "oneOf": [
    { "$ref": "#/$defs/profile" },
    { "$ref": "#/$defs/challenge" },
    { "$ref": "#/$defs/ceremony" },
    { "$ref": "#/$defs/acknowledgement" },
    { "$ref": "#/$defs/executionRecord" }
  ],
  "$defs": {
    "safeInteger": {
      "type": "integer",
      "minimum": -9007199254740991,
      "maximum": 9007199254740991
    },
    "materialActionScalar": {
      "oneOf": [
        { "type": "null" },
        { "type": "boolean" },
        { "$ref": "#/$defs/safeInteger" },
        { "type": "string", "maxLength": 4096 }
      ]
    },
    "materialFieldName": {
      "type": "string",
      "pattern": "^@?[A-Za-z0-9][A-Za-z0-9_. -]{0,127}$"
    },
    "controlledAction": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 64,
      "propertyNames": { "$ref": "#/$defs/materialFieldName" },
      "additionalProperties": { "$ref": "#/$defs/materialActionScalar" }
    },
    "canonicalInstant": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}\\.[0-9]{3}Z$"
    },
    "identifier": {
      "type": "string",
      "pattern": "^[A-Za-z0-9:_.@-]{3,256}$"
    },
    "attestationKeyId": {
      "type": "string",
      "pattern": "^[A-Za-z0-9:._+/=-]{3,512}$"
    },
    "origin": {
      "type": "string",
      "pattern": "^(https://|android:apk-key-hash:[A-Za-z0-9_-]{43}$)"
    },
    "base64url": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_-]+$"
    },
    "hash": {
      "type": "string",
      "pattern": "^(sha256:)?[0-9a-f]{64}$"
    },
    "jsonObject": {
      "type": "object"
    },
    "presentation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["@version", "title", "summary", "risk", "consequence", "material_fields"],
      "properties": {
        "@version": { "const": "EP-MOBILE-PRESENTATION-v1" },
        "title": { "type": "string", "minLength": 1, "maxLength": 200 },
        "summary": { "type": "string", "minLength": 1, "maxLength": 2000 },
        "risk": { "type": "string", "minLength": 1, "maxLength": 128 },
        "consequence": { "type": "string", "maxLength": 2000 },
        "material_fields": {
          "type": "object",
          "minProperties": 1,
          "maxProperties": 64,
          "description": "Closed material projection. A conforming implementation requires exactly the action's keys and each scalar's deterministic lossless textual form before issuing or signing a challenge.",
          "propertyNames": { "$ref": "#/$defs/materialFieldName" },
          "additionalProperties": { "type": "string", "maxLength": 4096 }
        }
      }
    },
    "mobileBinding": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "profile_hash",
        "platform",
        "app_id",
        "device_key_id",
        "credential_id",
        "attestation_key_id"
      ],
      "properties": {
        "profile": { "const": "EP-MOBILE-CHALLENGE-v1" },
        "profile_hash": { "$ref": "#/$defs/hash" },
        "platform": { "enum": ["ios", "android"] },
        "app_id": { "$ref": "#/$defs/identifier" },
        "device_key_id": { "$ref": "#/$defs/identifier" },
        "credential_id": { "$ref": "#/$defs/base64url" },
        "attestation_key_id": { "$ref": "#/$defs/attestationKeyId" }
      }
    },
    "authorizationContext": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ep_version",
        "context_type",
        "action_hash",
        "policy_id",
        "policy_hash",
        "initiator",
        "approver",
        "approver_index",
        "required_approvals",
        "nonce",
        "issued_at",
        "expires_at",
        "decision",
        "display_hash",
        "mobile_binding"
      ],
      "properties": {
        "ep_version": { "const": "1.0" },
        "context_type": { "const": "ep.signoff.v1" },
        "action_hash": { "$ref": "#/$defs/hash" },
        "policy_id": { "type": ["string", "null"] },
        "policy_hash": {
          "oneOf": [
            { "$ref": "#/$defs/hash" },
            { "type": "null" }
          ]
        },
        "initiator": { "$ref": "#/$defs/identifier" },
        "approver": { "$ref": "#/$defs/identifier" },
        "approver_index": { "const": 1 },
        "required_approvals": { "const": 1 },
        "nonce": { "$ref": "#/$defs/identifier" },
        "issued_at": { "$ref": "#/$defs/canonicalInstant" },
        "expires_at": { "$ref": "#/$defs/canonicalInstant" },
        "decision": { "enum": ["approved", "denied"] },
        "display_hash": { "$ref": "#/$defs/hash" },
        "mobile_binding": { "$ref": "#/$defs/mobileBinding" }
      }
    },
    "enrollment": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "device_key_id",
        "credential_id",
        "public_key_spki",
        "approver_id",
        "platform",
        "app_id",
        "attestation_key_id",
        "status",
        "valid_from",
        "valid_to",
        "sign_count"
      ],
      "properties": {
        "device_key_id": { "$ref": "#/$defs/identifier" },
        "credential_id": { "$ref": "#/$defs/base64url" },
        "public_key_spki": { "$ref": "#/$defs/base64url" },
        "approver_id": { "$ref": "#/$defs/identifier" },
        "platform": { "enum": ["ios", "android"] },
        "app_id": { "$ref": "#/$defs/identifier" },
        "attestation_key_id": { "$ref": "#/$defs/attestationKeyId" },
        "status": { "enum": ["active", "revoked"] },
        "valid_from": { "$ref": "#/$defs/canonicalInstant" },
        "valid_to": { "$ref": "#/$defs/canonicalInstant" },
        "sign_count": { "type": "integer", "minimum": 0, "maximum": 9007199254740991 }
      }
    },
    "profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "@version",
        "profile_id",
        "rp_id",
        "allowed_origins",
        "accepted_apps",
        "requirements",
        "enrollments",
        "profile_hash"
      ],
      "properties": {
        "@version": { "const": "EP-MOBILE-RELIANCE-PROFILE-v1" },
        "profile_id": { "$ref": "#/$defs/identifier" },
        "rp_id": { "type": "string", "minLength": 1, "maxLength": 253 },
        "allowed_origins": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/origin" }
        },
        "accepted_apps": {
          "type": "object",
          "additionalProperties": false,
          "required": ["ios", "android"],
          "properties": {
            "ios": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" } },
            "android": { "type": "array", "uniqueItems": true, "items": { "$ref": "#/$defs/identifier" } }
          }
        },
        "requirements": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "attestation_required",
            "hardware_backed_required",
            "strong_integrity_required",
            "max_challenge_age_ms",
            "counter_policy"
          ],
          "properties": {
            "attestation_required": { "type": "boolean" },
            "hardware_backed_required": { "type": "boolean" },
            "strong_integrity_required": { "type": "boolean" },
            "max_challenge_age_ms": { "type": "integer", "minimum": 10000, "maximum": 900000 },
            "counter_policy": { "enum": ["ignore", "monotonic_if_nonzero", "registration_baseline"] }
          }
        },
        "enrollments": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/enrollment" }
        },
        "profile_hash": { "$ref": "#/$defs/hash" }
      }
    },
    "challenge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "@version",
        "challenge_profile",
        "challenge_id",
        "nonce",
        "action",
        "action_hash",
        "profile_hash",
        "authorization_context",
        "webauthn",
        "presentation",
        "issued_at",
        "expires_at",
        "attestation"
      ],
      "properties": {
        "@version": { "const": "AE-CHALLENGE-v1" },
        "challenge_profile": { "const": "EP-MOBILE-CHALLENGE-v1" },
        "challenge_id": { "$ref": "#/$defs/identifier" },
        "nonce": { "$ref": "#/$defs/identifier" },
        "action": { "$ref": "#/$defs/controlledAction" },
        "action_hash": { "$ref": "#/$defs/hash" },
        "profile_hash": { "$ref": "#/$defs/hash" },
        "authorization_context": { "$ref": "#/$defs/authorizationContext" },
        "webauthn": {
          "type": "object",
          "additionalProperties": false,
          "required": ["rp_id", "challenge", "credential_ids", "user_verification", "timeout_ms"],
          "properties": {
            "rp_id": { "type": "string", "minLength": 1 },
            "challenge": { "$ref": "#/$defs/base64url" },
            "credential_ids": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/base64url" } },
            "user_verification": { "const": "required" },
            "timeout_ms": { "type": "integer", "minimum": 1, "maximum": 900000 }
          }
        },
        "presentation": { "$ref": "#/$defs/presentation" },
        "issued_at": { "$ref": "#/$defs/canonicalInstant" },
        "expires_at": { "$ref": "#/$defs/canonicalInstant" },
        "attestation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["required", "format", "binding", "request_hash"],
          "properties": {
            "required": { "type": "boolean" },
            "format": { "enum": ["apple-app-attest", "play-integrity-standard"] },
            "binding": { "$ref": "#/$defs/jsonObject" },
            "request_hash": { "$ref": "#/$defs/base64url" }
          }
        }
      }
    },
    "ceremony": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "@version",
        "challenge_id",
        "nonce",
        "platform",
        "app_id",
        "device_key_id",
        "credential_id",
        "attestation_key_id",
        "decision",
        "display_hash",
        "signoff",
        "attestation"
      ],
      "properties": {
        "@version": { "const": "EP-MOBILE-CEREMONY-v1" },
        "challenge_id": { "$ref": "#/$defs/identifier" },
        "nonce": { "$ref": "#/$defs/identifier" },
        "platform": { "enum": ["ios", "android"] },
        "app_id": { "$ref": "#/$defs/identifier" },
        "device_key_id": { "$ref": "#/$defs/identifier" },
        "credential_id": { "$ref": "#/$defs/base64url" },
        "attestation_key_id": { "$ref": "#/$defs/attestationKeyId" },
        "decision": { "enum": ["approved", "denied"] },
        "display_hash": { "$ref": "#/$defs/hash" },
        "signoff": {
          "type": "object",
          "additionalProperties": false,
          "required": ["context", "webauthn"],
          "properties": {
            "context": { "$ref": "#/$defs/authorizationContext" },
            "webauthn": {
              "type": "object",
              "additionalProperties": false,
              "required": ["authenticator_data", "client_data_json", "signature"],
              "properties": {
                "authenticator_data": { "$ref": "#/$defs/base64url" },
                "client_data_json": { "$ref": "#/$defs/base64url" },
                "signature": { "$ref": "#/$defs/base64url" }
              }
            }
          }
        },
        "attestation": {
          "type": "object",
          "additionalProperties": false,
          "required": ["format", "token"],
          "properties": {
            "format": { "enum": ["apple-app-attest", "play-integrity-standard"] },
            "token": { "$ref": "#/$defs/base64url" },
            "device_key_signature": { "$ref": "#/$defs/base64url" }
          }
        }
      },
      "allOf": [
        {
          "if": { "properties": { "platform": { "const": "android" } } },
          "then": { "properties": { "attestation": { "required": ["format", "token", "device_key_signature"] } } },
          "else": { "properties": { "attestation": { "not": { "required": ["device_key_signature"] } } } }
        }
      ]
    },
    "acknowledgement": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "@version",
        "verdict",
        "decision",
        "context_hash",
        "approver_id",
        "device_key_id",
        "receipt_id",
        "recorded_at",
        "signer_key_id",
        "signature"
      ],
      "properties": {
        "@version": { "const": "EP-MOBILE-ACK-v1" },
        "verdict": { "const": "verified" },
        "decision": { "enum": ["approved", "denied"] },
        "context_hash": { "$ref": "#/$defs/hash" },
        "approver_id": { "$ref": "#/$defs/identifier" },
        "device_key_id": { "$ref": "#/$defs/identifier" },
        "receipt_id": { "type": ["string", "null"] },
        "recorded_at": { "$ref": "#/$defs/canonicalInstant" },
        "signer_key_id": { "$ref": "#/$defs/identifier" },
        "signature": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "value"],
          "properties": {
            "algorithm": { "const": "Ed25519" },
            "value": { "$ref": "#/$defs/base64url" }
          }
        }
      }
    },
    "executionRecord": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "@version",
        "statement_type",
        "verdict",
        "decision",
        "challenge_id",
        "action_hash",
        "profile_hash",
        "context_hash",
        "approver_id",
        "device_key_id",
        "platform",
        "app_id",
        "attestation_format",
        "receipt_id",
        "audit_record_id",
        "audit_record_hash",
        "online_checks",
        "operator_assertions",
        "recorded_at",
        "signer_key_id",
        "signature"
      ],
      "properties": {
        "@version": { "const": "EP-MOBILE-EXECUTION-RECORD-v1" },
        "statement_type": { "const": "operator_runtime_attestation" },
        "verdict": { "const": "verified" },
        "decision": { "enum": ["approved", "denied"] },
        "challenge_id": { "$ref": "#/$defs/identifier" },
        "action_hash": { "$ref": "#/$defs/hash" },
        "profile_hash": { "$ref": "#/$defs/hash" },
        "context_hash": { "$ref": "#/$defs/hash" },
        "approver_id": { "$ref": "#/$defs/identifier" },
        "device_key_id": { "$ref": "#/$defs/identifier" },
        "platform": { "enum": ["ios", "android"] },
        "app_id": { "$ref": "#/$defs/identifier" },
        "attestation_format": { "enum": ["apple-app-attest", "play-integrity-standard"] },
        "receipt_id": { "$ref": "#/$defs/identifier" },
        "audit_record_id": { "type": "string", "minLength": 16, "maxLength": 256 },
        "audit_record_hash": { "$ref": "#/$defs/hash" },
        "online_checks": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "profile",
            "freshness",
            "action",
            "presentation",
            "signed_context",
            "platform",
            "app",
            "device_key",
            "origin",
            "webauthn",
            "attestation"
          ],
          "properties": {
            "profile": { "const": true },
            "freshness": { "const": true },
            "action": { "const": true },
            "presentation": { "const": true },
            "signed_context": { "const": true },
            "platform": { "const": true },
            "app": { "const": true },
            "device_key": { "const": true },
            "origin": { "const": true },
            "webauthn": { "const": true },
            "attestation": { "const": true }
          }
        },
        "operator_assertions": {
          "type": "object",
          "additionalProperties": false,
          "required": ["platform_attestation", "challenge_consumption", "durable_audit"],
          "properties": {
            "platform_attestation": { "const": "verified_at_execution" },
            "challenge_consumption": { "const": "consumed_before_audit_record" },
            "durable_audit": { "const": "recorded" }
          }
        },
        "recorded_at": { "$ref": "#/$defs/canonicalInstant" },
        "signer_key_id": { "$ref": "#/$defs/identifier" },
        "signature": {
          "type": "object",
          "additionalProperties": false,
          "required": ["algorithm", "value"],
          "properties": {
            "algorithm": { "const": "Ed25519" },
            "value": { "$ref": "#/$defs/base64url" }
          }
        }
      }
    }
  }
}
