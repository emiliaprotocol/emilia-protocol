{
  "@version": "EMILIA-PROPOSAL-TO-EFFECT-VECTORS-v1",
  "description": "Executable profile vectors for the non-authoritative proposal, exact-action binding, one-time admission, and indeterminate-effect lifecycle.",
  "profile": {
    "id": "payment-release",
    "action_type": "payment.release",
    "authorization_flow": "EP-APPROVAL-v1",
    "aeb_requirement_ref": "requirement:proposal-to-effect"
  },
  "action": {
    "action_type": "payment.release",
    "amount_usd": 40000,
    "currency": "USD",
    "payment_instruction_id": "pi_eg1_40000",
    "beneficiary_account_hash": "sha256:eg1-beneficiary"
  },
  "expected": {
    "caid": "caid:1:payment.release.1:jcs-sha256:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA",
    "action_digest": "sha256:4593a48d22290c383cdb2dca8b8136a213151ad323b7eca79904ca88901a18f0",
    "aeb_action_digest": "sha256:4593a48d22290c383cdb2dca8b8136a213151ad323b7eca79904ca88901a18f0"
  },
  "vectors": [
    {
      "id": "proposal_is_not_authority",
      "expect": { "signature": false, "permit": false, "authorized": false }
    },
    {
      "id": "mutated_material_action_refused",
      "mutation": { "field": "amount_usd", "value": 40001 },
      "expect": { "error": "proposal_action_digest_mismatch", "effect_invoked": false }
    },
    {
      "id": "stale_aeb_refused",
      "expect": { "reason": "aeb_evaluation_refused", "effect_invoked": false }
    },
    {
      "id": "unguarded_gate_selector_refused",
      "expect": { "reason": "gate_profile_not_receipt_guarded", "effect_invoked": false }
    },
    {
      "id": "fresh_receipt_cannot_replay_consumed_operation",
      "expect": { "reason": "aeb_consumption_conflict", "effect_count": 1 }
    },
    {
      "id": "indeterminate_effect_freezes_operation",
      "expect": { "state": "RESERVED", "blind_retry": false }
    },
    {
      "id": "authenticated_not_committed_reconciliation_releases_operation",
      "expect": { "outcome": "NOT_COMMITTED", "state": "AVAILABLE" }
    },
    {
      "id": "executed_effect_commit_failure_stays_reserved",
      "expect": {
        "error": "EMILIA_PROPOSAL_TO_EFFECT_COMMIT_FAILED",
        "aeb_state": "RESERVED",
        "attempt_state": "INDETERMINATE"
      }
    }
  ]
}
