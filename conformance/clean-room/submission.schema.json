{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emiliaprotocol.ai/schemas/clean-room-submission.v1.json",
  "title": "EP clean-room implementation submission",
  "type": "object",
  "additionalProperties": false,
  "required": ["@version", "implementation", "runner", "independence"],
  "properties": {
    "@version": { "const": "EP-CLEAN-ROOM-SUBMISSION-v1" },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["implementation_id", "organization", "language", "version", "source_repository", "source_commit", "license_spdx", "build_instructions", "dependencies"],
      "properties": {
        "implementation_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$" },
        "organization": { "type": "string", "minLength": 2 },
        "language": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "source_repository": { "type": "string", "format": "uri" },
        "source_commit": { "type": "string", "pattern": "^(?:[0-9a-f]{40,64}|workspace)$" },
        "license_spdx": { "type": "string", "minLength": 2 },
        "build_instructions": { "type": "string", "minLength": 10 },
        "dependencies": { "type": "array", "items": { "type": "string", "minLength": 1 }, "uniqueItems": true }
      }
    },
    "runner": {
      "type": "object",
      "additionalProperties": false,
      "required": ["protocol", "artifact_argument_index", "artifact_sha256", "fixed_arguments"],
      "properties": {
        "protocol": { "const": "EP-CONFORMANCE-FILE-RUNNER-v1" },
        "artifact_argument_index": { "type": "integer", "minimum": -1 },
        "artifact_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "fixed_arguments": { "type": "array", "items": { "type": "string" } }
      }
    },
    "independence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claimed", "authors", "specification_inputs", "specification_bundle_sha256", "reference_source_access", "emilia_affiliation", "statement"],
      "properties": {
        "claimed": { "type": "boolean" },
        "authors": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
        "specification_inputs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
        "specification_bundle_sha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "reference_source_access": { "enum": ["none", "reference_port"] },
        "emilia_affiliation": { "enum": ["none", "maintainer", "contractor"] },
        "statement": { "type": "string", "minLength": 20 }
      }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "attestor_relationship", "signature_base64url"],
      "properties": {
        "algorithm": { "const": "Ed25519" },
        "key_id": { "type": "string", "minLength": 3 },
        "attestor_relationship": { "enum": ["independent", "implementation_organization", "self"] },
        "signature_base64url": { "type": "string", "minLength": 40 }
      }
    }
  }
}
