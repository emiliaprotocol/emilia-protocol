{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://emiliaprotocol.ai/schemas/clean-room-submission.v1.json",
  "title": "EP clean-room implementation submission",
  "type": "object",
  "additionalProperties": false,
  "required": ["@version", "implementation", "independence"],
  "properties": {
    "@version": { "const": "EP-CLEAN-ROOM-SUBMISSION-v1" },
    "implementation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["implementation_id", "organization", "language", "version", "source_repository", "source_commit", "license_spdx"],
      "properties": {
        "implementation_id": { "type": "string", "pattern": "^[a-z0-9][a-z0-9._-]{2,63}$" },
        "organization": { "type": "string", "minLength": 2 },
        "language": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "source_repository": { "type": "string", "format": "uri" },
        "source_commit": { "type": "string", "minLength": 7 },
        "license_spdx": { "type": "string", "minLength": 2 }
      }
    },
    "independence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claimed", "authors", "specification_inputs", "reference_source_access"],
      "properties": {
        "claimed": { "type": "boolean" },
        "authors": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
        "specification_inputs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 2 } },
        "reference_source_access": { "enum": ["none", "reference_port"] },
        "statement": { "type": "string", "minLength": 20 }
      }
    },
    "attestation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["algorithm", "key_id", "signature_base64url"],
      "properties": {
        "algorithm": { "const": "Ed25519" },
        "key_id": { "type": "string", "minLength": 3 },
        "signature_base64url": { "type": "string", "minLength": 40 }
      }
    }
  }
}
