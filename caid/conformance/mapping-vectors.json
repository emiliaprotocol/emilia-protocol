{
  "@version": "CAID-ACTION-MAPPING-VECTORS-v1",
  "description": "Shared vectors for profile-bounded material-action equivalence. A result is content correlation only; it never authorizes an action.",
  "suite": "jcs-sha256",
  "definitions": [
    {
      "action_type": "order.place.1",
      "status": "active",
      "risk_class": "irreversible-financial",
      "summary": "Placement of a purchase order committing the buyer to payment.",
      "required_fields": [
        { "name": "order_id", "type": "string" },
        { "name": "merchant_ref", "type": "digest", "notes": "sha256:<lowercase hex> of the normalized merchant identifier" },
        { "name": "total_amount", "type": "amount-string", "notes": "grand total including tax and shipping, in order currency" },
        { "name": "currency", "type": "enum", "values_ref": "ISO 4217 alpha-3" },
        { "name": "items_digest", "type": "digest", "notes": "sha256:<lowercase hex> of the canonical line-item list (sku, quantity, unit price per line)" },
        { "name": "customer_ref", "type": "digest", "notes": "sha256:<lowercase hex> of the normalized customer identifier" },
        { "name": "fulfillment_ref", "type": "digest", "notes": "sha256:<lowercase hex> of the canonical delivery, pickup, or digital-fulfillment target" }
      ],
      "optional_fields": [
        { "name": "shipping_method", "type": "string" }
      ],
      "digest_notes": "merchant, customer, fulfillment target, and canonical line items are material; an order identifier alone is not globally sufficient",
      "references": []
    },
    {
      "action_type": "travel.cancel-notify.1",
      "status": "active",
      "risk_class": "external-communication",
      "summary": "Cancellation of a travel reservation with a time constraint and a secondary notification action.",
      "required_fields": [
        { "name": "primary_action", "type": "string", "notes": "SILP root intent, for example !CANCEL" },
        { "name": "resource", "type": "string", "notes": "The primary action's material target" },
        { "name": "cancel_time", "type": "string", "notes": "The primary action's material time slot" },
        { "name": "secondary_action", "type": "string", "notes": "A material secondary action, for example !EMAIL" },
        { "name": "notification_recipient", "type": "string", "notes": "The secondary action's material recipient" },
        { "name": "constraint_type", "type": "string" },
        { "name": "constraint_value", "type": "string" },
        { "name": "constraint_time", "type": "string" },
        { "name": "constraint_subject", "type": "string" },
        { "name": "entities_digest", "type": "digest", "notes": "sha256:<lowercase hex> of the complete ordered SILP entity list, including entity/action associations" },
        { "name": "constraints_digest", "type": "digest", "notes": "sha256:<lowercase hex> of the complete ordered SILP constraint list" },
        { "name": "alternatives_digest", "type": "digest", "notes": "sha256:<lowercase hex> of the complete SILP alternatives list" },
        { "name": "sequence_digest", "type": "digest", "notes": "sha256:<lowercase hex> of the declared SILP action sequence" }
      ],
      "optional_fields": [],
      "digest_notes": "The root intent, complete ordered entity and constraint collections, declared action sequence, all alternatives, primary target and timing, and secondary action and recipient are material. SILP correlation metadata such as req_id, session_id, priority, confidence, and output hints are not material unless a separate action profile says otherwise.",
      "references": ["draft-hwang-silp-protocol-01"]
    }
  ],
  "profiles": {
    "ep-action-v1": {
      "@version": "CAID-MAPPING-PROFILE-v1",
      "profile_id": "urn:emilia:mapping:ep-action-to-order-place:1",
      "source_format": {
        "media_type": "application/ep-action+json",
        "schema": "urn:emilia:ep-action:1",
        "version": "1"
      },
      "target_action_type": "order.place.1",
      "loss_policy": "no-material-field-loss",
      "material_source_paths": [
        "/target/checkout_id",
        "/target/merchant_id",
        "/parameters/total_amount",
        "/parameters/currency",
        "/parameters/line_items",
        "/target/customer_id",
        "/target/fulfillment"
      ],
      "rules": [
        { "source_path": "/target/checkout_id", "target_field": "order_id", "transform": "copy" },
        { "source_path": "/target/merchant_id", "target_field": "merchant_ref", "transform": "sha256-utf8" },
        { "source_path": "/parameters/total_amount", "target_field": "total_amount", "transform": "copy" },
        { "source_path": "/parameters/currency", "target_field": "currency", "transform": "copy" },
        { "source_path": "/parameters/line_items", "target_field": "items_digest", "transform": "sha256-jcs" },
        { "source_path": "/target/customer_id", "target_field": "customer_ref", "transform": "sha256-utf8" },
        { "source_path": "/target/fulfillment", "target_field": "fulfillment_ref", "transform": "sha256-jcs" }
      ]
    },
    "ap2-checkout-v1": {
      "@version": "CAID-MAPPING-PROFILE-v1",
      "profile_id": "urn:emilia:mapping:ap2-checkout-to-order-place:1",
      "source_format": {
        "media_type": "application/ap2-checkout+json",
        "schema": "https://ap2-protocol.org/schemas/checkout-mandate",
        "version": "1"
      },
      "target_action_type": "order.place.1",
      "loss_policy": "no-material-field-loss",
      "material_source_paths": [
        "/checkout/order_id",
        "/checkout/merchant_id",
        "/checkout/total_amount",
        "/checkout/currency",
        "/checkout/line_items",
        "/checkout/customer_id",
        "/checkout/fulfillment"
      ],
      "rules": [
        { "source_path": "/checkout/order_id", "target_field": "order_id", "transform": "copy" },
        { "source_path": "/checkout/merchant_id", "target_field": "merchant_ref", "transform": "sha256-utf8" },
        { "source_path": "/checkout/total_amount", "target_field": "total_amount", "transform": "copy" },
        { "source_path": "/checkout/currency", "target_field": "currency", "transform": "copy" },
        { "source_path": "/checkout/line_items", "target_field": "items_digest", "transform": "sha256-jcs" },
        { "source_path": "/checkout/customer_id", "target_field": "customer_ref", "transform": "sha256-utf8" },
        { "source_path": "/checkout/fulfillment", "target_field": "fulfillment_ref", "transform": "sha256-jcs" }
      ]
    },
    "silp-cancel-email-v1": {
      "@version": "CAID-MAPPING-PROFILE-v1",
      "profile_id": "urn:emilia:mapping:silp-cancel-email-to-travel-cancel-notify:1",
      "source_format": {
        "media_type": "application/silp-ir+json",
        "schema": "https://github.com/Juwan-Hwang/polyglotir#silp-ir",
        "version": "ir-v0.1"
      },
      "target_action_type": "travel.cancel-notify.1",
      "loss_policy": "no-material-field-loss",
      "material_source_paths": [
        "/intent",
        "/entities/0/value",
        "/entities/1/value",
        "/entities/2/action",
        "/entities/2/value",
        "/constraints/0/type",
        "/constraints/0/value",
        "/constraints/0/time",
        "/constraints/0/subject",
        "/entities",
        "/constraints",
        "/alternatives",
        "/meta/seq"
      ],
      "rules": [
        { "source_path": "/intent", "target_field": "primary_action", "transform": "copy" },
        { "source_path": "/entities/0/value", "target_field": "resource", "transform": "copy" },
        { "source_path": "/entities/1/value", "target_field": "cancel_time", "transform": "copy" },
        { "source_path": "/entities/2/action", "target_field": "secondary_action", "transform": "copy" },
        { "source_path": "/entities/2/value", "target_field": "notification_recipient", "transform": "copy" },
        { "source_path": "/constraints/0/type", "target_field": "constraint_type", "transform": "copy" },
        { "source_path": "/constraints/0/value", "target_field": "constraint_value", "transform": "copy" },
        { "source_path": "/constraints/0/time", "target_field": "constraint_time", "transform": "copy" },
        { "source_path": "/constraints/0/subject", "target_field": "constraint_subject", "transform": "copy" },
        { "source_path": "/entities", "target_field": "entities_digest", "transform": "sha256-jcs" },
        { "source_path": "/constraints", "target_field": "constraints_digest", "transform": "sha256-jcs" },
        { "source_path": "/alternatives", "target_field": "alternatives_digest", "transform": "sha256-jcs" },
        { "source_path": "/meta/seq", "target_field": "sequence_digest", "transform": "sha256-jcs" }
      ]
    }
  },
  "sources": {
    "ep-order": {
      "ep_version": "1.0",
      "action_type": "commerce.checkout",
      "target": {
        "merchant_id": "merch_acme_supplies",
        "checkout_id": "ord_2026_9911",
        "customer_id": "cust_treasury_777",
        "fulfillment": { "kind": "shipping", "destination_id": "addr_denver_42" }
      },
      "parameters": {
        "currency": "USD",
        "total_amount": "129.99",
        "line_items": [
          { "sku": "sku_widget_a", "title": "Widget A", "quantity": 2, "unit_price": "50.00" },
          { "sku": "sku_ship_std", "title": "Standard shipping", "quantity": 1, "unit_price": "29.99" }
        ]
      }
    },
    "ap2-order": {
      "vct": "mandate.checkout.1",
      "checkout": {
        "order_id": "ord_2026_9911",
        "merchant_id": "merch_acme_supplies",
        "customer_id": "cust_treasury_777",
        "fulfillment": { "kind": "shipping", "destination_id": "addr_denver_42" },
        "currency": "USD",
        "total_amount": "129.99",
        "line_items": [
          { "sku": "sku_widget_a", "title": "Widget A", "quantity": 2, "unit_price": "50.00" },
          { "sku": "sku_ship_std", "title": "Standard shipping", "quantity": 1, "unit_price": "29.99" }
        ],
        "created_at": "2026-07-08T11:59:00Z"
      },
      "checkout_hash": "native-ap2-digest-verified-by-the-ap2-verifier"
    },
    "silp-cancel-email": {
      "silp": "v1",
      "version": "ir-v0.1",
      "intent": "!CANCEL",
      "entities": [
        { "id": "act", "value": "flight", "action": "!CANCEL" },
