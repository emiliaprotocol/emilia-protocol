        { "id": "act", "value": "zhangsan", "action": "!EMAIL" }
      ],
      "constraints": [
        { "type": "loc", "value": "Beijing", "time": "t+1am", "subject": "me" }
      ],
      "alternatives": [],
      "meta": {
        "req_id": "a1b2c3d4",
        "session_id": "s1",
        "priority": 7,
        "confidence": 1,
        "seq": ["!CANCEL", "!EMAIL"],
        "out": "code"
      }
    },
    "silp-cancel-email-metadata-variant": {
      "silp": "v1",
      "version": "ir-v0.1",
      "intent": "!CANCEL",
      "entities": [
        { "id": "act", "value": "flight", "action": "!CANCEL" },
        { "id": "time", "value": "t+1pm", "action": "!CANCEL" },
        { "id": "act", "value": "zhangsan", "action": "!EMAIL" }
      ],
      "constraints": [
        { "type": "loc", "value": "Beijing", "time": "t+1am", "subject": "me" }
      ],
      "alternatives": [],
      "meta": {
        "req_id": "d4c3b2a1",
        "session_id": "s2",
        "priority": 1,
        "confidence": 0,
        "seq": ["!CANCEL", "!EMAIL"],
        "out": "json"
      }
    }
  },
  "vectors": [
    {
      "id": "equivalent-native-formats",
      "left": { "source": "ep-order", "profile": "ep-action-v1", "pin": "profile" },
      "right": { "source": "ap2-order", "profile": "ap2-checkout-v1", "pin": "profile" },
      "expect": { "verdict": "EQUIVALENT_UNDER_PROFILE", "reasons": [] }
    },
    {
      "id": "irrelevant-source-metadata-does-not-change-projection",
      "left": { "source": "ep-order", "profile": "ep-action-v1", "pin": "profile" },
      "right": { "source": "ap2-order", "profile": "ap2-checkout-v1", "pin": "profile" },
      "mutations": [
        { "side": "right", "target": "source", "op": "set", "path": "/transport_trace", "value": "trace-991" }
      ],
      "expect": { "verdict": "EQUIVALENT_UNDER_PROFILE", "reasons": [] }
    },
    {
      "id": "amount-mismatch",
      "left": { "source": "ep-order", "profile": "ep-action-v1", "pin": "profile" },
      "right": { "source": "ap2-order", "profile": "ap2-checkout-v1", "pin": "profile" },
      "mutations": [
        { "side": "right", "target": "source", "op": "set", "path": "/checkout/total_amount", "value": "130.00" }
      ],
      "expect": { "verdict": "NOT_EQUIVALENT", "reasons": ["material_projection_mismatch"] }
    },
    {
      "id": "merchant-mismatch",
      "left": { "source": "ep-order", "profile": "ep-action-v1", "pin": "profile" },
