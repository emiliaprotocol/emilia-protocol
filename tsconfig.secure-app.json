{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "skipLibCheck": true,
    "noImplicitAny": false,
    "types": ["react", "node"]
  },
  "include": [
    "apps/secure-app/App.tsx",
    "apps/secure-app/index.ts",
    "apps/secure-app/babel.config.js",
    "apps/secure-app/lib/**/*.ts",
    "apps/secure-app/lib/**/*.mjs"
  ],
  "exclude": [
    "**/*.test.js",
    "**/*.test.mjs",
    "**/node_modules/**"
  ]
}
