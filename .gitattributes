# Line-ending policy. Some files here are CRYPTOGRAPHICALLY SIGNIFICANT: the
# external-verification suite_digest is SHA-256 over the RAW BYTES of each
# conformance vector file. A Windows clone with the default core.autocrlf=true
# rewrites those files to CRLF on checkout, silently breaking the digest for any
# external verifier (this bit a real implementer twice). Pin them to verbatim
# bytes so every clone, on every OS, reproduces our published digests.
conformance/vectors/** -text
examples/external-verification/statements/** -text

# Everything else: normalize to LF in the repo and on checkout.
* text=auto eol=lf

# Source files are always reviewable as text, including cleanup commits that
# remove accidental control bytes from an older blob.
*.js diff
*.mjs diff
*.cjs diff

# Binaries: never touch.
*.pdf binary
*.png binary
*.jpg binary
*.gif binary
*.mp4 binary
*.woff2 binary

# ── Linguist: keep GitHub's language stats about SOURCE, not build output ────
# Compiled package output shipped in-repo (regenerated by each package's build).
packages/*/dist/** linguist-generated=true
lib/dist/** linguist-generated=true
# Node-20 standalone-runtime companions: transpiled twins of .ts/.mts sources,
# regenerated by scripts/build-standalone-runtimes.mjs (see the BEGIN block
# below, kept in sync by that script's --check gate).
# Vendored byte-identical copies of packages/verify's compiled browser verifier
# (pinned by tests/verify-web-consistency.test.js).
lib/verify-web.js linguist-vendored=true
lib/strict-json.js linguist-vendored=true

