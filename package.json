{
  "name": "emilia-protocol",
  "version": "1.0.0",
  "description": "EMILIA Protocol — Trust enforcement for high-risk actions. Open protocol for pre-action binding, policy-bound verification, one-time consumption, and accountable human signoff.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "check:protocol": "node scripts/check-protocol-discipline.js",
    "check:demo-key": "node scripts/check-demo-key-isolation.js",
    "gov:check": "node scripts/gov-readiness-check.mjs",
    "gov:db-contract": "node scripts/db-contract.mjs",
    "schema:security": "node scripts/db-contract.mjs",
    "keys:inventory": "node scripts/key-inventory.mjs",
    "schema:reconcile": "node scripts/migration-reconcile.mjs",
    "gov:drill:key-compromise": "node scripts/drills/key-compromise-drill.mjs",
    "reconstitute": "node scripts/replay-protocol.js --reconstitute",
    "test:mutation": "stryker run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "setup": "npm install && cp .env.example .env.local 2>/dev/null || true && echo 'Setup complete. Edit .env.local with your credentials.'",
    "prepare": "husky",
    "conformance": "node conformance/run.mjs",
    "conformance:signoffs": "node conformance/run-signoffs.mjs",
    "conformance:federation": "node conformance/federation.mjs",
    "conformance:operator2": "node conformance/operator2/verify-live.mjs"
  },
  "lint-staged": {
    "{app,lib,components}/**/*.{js,mjs,ts,tsx}": [
      "eslint --max-warnings=0",
      "node scripts/check-license-headers.js"
    ]
  },
  "dependencies": {
    "@node-saml/node-saml": "^5.1.0",
    "@remotion/player": "^4.0.481",
    "@sentry/nextjs": "10.59.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.1",
    "@supabase/supabase-js": "^2.108.2",
    "cbor-x": "^1.6.4",
    "jose": "^6.2.3",
    "mammoth": "^1.12.0",
    "mcp-handler": "^1.1.0",
    "motion": "^12.40.0",
    "next": "^15.5.19",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remotion": "^4.0.452",
    "stripe": "^22.2.2",
    "viem": "^2.53.1",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3"
  },
  "overrides": {
    "rollup": "^4.22.5",
    "postcss": "^8.5.12",
    "qs": "^6.15.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.2.9",
    "fast-check": "^4.8.0",
    "husky": "^9.0.0",
    "lint-staged": "^17.0.8",
    "pg": "^8.22.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
