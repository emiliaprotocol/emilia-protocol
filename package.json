{
  "name": "emilia-protocol",
  "version": "1.0.0",
  "private": true,
  "description": "EMILIA Protocol \u2014 an open verification protocol and consequence firewall for exact, authorized machine actions.",
  "homepage": "https://www.emiliaprotocol.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/emiliaprotocol/emilia-protocol.git"
  },
  "bugs": {
    "url": "https://github.com/emiliaprotocol/emilia-protocol/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "demo:receipt-program": "node examples/receipt-program/demo.mjs",
    "ml:selftest": "node --test ml/risk-eval/classifiers/heuristic.selftest.mjs ml/risk-eval/classifiers/tinker.selftest.mjs && python3 ml/train/prepare.selftest.py",
    "ml:eval": "node ml/risk-eval/eval.mjs heuristic --min-perimeter=100",
    "ml:gate": "npm run ml:selftest && npm run ml:eval",
    "test:ml": "npm run ml:gate",
    "typecheck:core": "tsc -p tsconfig.core.json",
    "typecheck:lib": "tsc -p tsconfig.lib.json",
    "typecheck:rest": "tsc -p tsconfig.rest.json",
    "typecheck:app": "tsc -p tsconfig.app.json",
    "typecheck:strict": "node scripts/typecheck-strict.mjs",
    "build:ts-runtime": "node scripts/build-ts-runtime.mjs",
    "build:standalone-runtimes": "node scripts/build-standalone-runtimes.mjs",
    "check:standalone-runtimes": "node scripts/build-standalone-runtimes.mjs --check",
    "typecheck:secure-app": "tsc -p tsconfig.secure-app.json",
    "typecheck:declarations": "tsc -p tsconfig.declarations.json",
    "typecheck:sdk": "tsc -p sdks/typescript/tsconfig.json --noEmit",
    "typecheck": "npm run typecheck:core && npm run typecheck:lib && npm run typecheck:rest && npm run typecheck:app && npm run typecheck:secure-app && npm run typecheck:declarations && npm run typecheck:sdk",
    "check:protocol": "node scripts/check-protocol-discipline.js && node scripts/check-write-discipline.js",
    "check:write-discipline": "node scripts/check-write-discipline.js",
    "check:repository-boundary": "node scripts/check-repository-boundary.js",
    "check:demo-key": "node scripts/check-demo-key-isolation.js",
    "check:admissibility": "node scripts/check-admissibility-registry.mjs",
    "check:security-case": "node --import ./scripts/ts-loader/register.mjs scripts/verify-security-case.mjs --execute",
    "security-case:emit": "node --import ./scripts/ts-loader/register.mjs scripts/verify-security-case.mjs --execute --emit security/security-case.json",
    "check:authority-claims": "node scripts/check-authority-claims.mjs",
    "check:runtime-bridge": "node scripts/check-runtime-bridge.mjs",
    "check:formal-traces": "node scripts/check-formal-runtime-traces.mjs --check",
    "sync:formal-traces": "node scripts/check-formal-runtime-traces.mjs --emit",
    "check:conformance-docs": "node scripts/check-conformance-doc-counts.mjs",
    "preprint:build": "SOURCE_DATE_EPOCH=1784419200 FORCE_SOURCE_DATE=1 tectonic -X compile papers/preprint/main.tex",
    "check:preprint": "node scripts/check-preprint-sync.mjs",
    "test:preprint": "node --test tests/preprint-sync.node.ts",
    "gov:check": "node scripts/gov-readiness-check.mjs",
    "gov:db-contract": "node scripts/db-contract.mjs",
    "schema:security": "node scripts/db-contract.mjs",
    "keys:inventory": "node scripts/key-inventory.mjs",
    "schema:reconcile": "node scripts/migration-reconcile.mjs",
    "gov:drill:key-compromise": "node scripts/drills/key-compromise-drill.mjs",
    "reconstitute": "node scripts/replay-protocol.js --reconstitute",
    "test:mutation": "EP_MUTATE_SRC=1 stryker run",
    "test:mutation:security": "EP_MUTATE_SRC=1 stryker run stryker.security.config.js",
    "test:mutation:aec": "EP_MUTATE_SRC=1 stryker run stryker.aec.config.js",
    "test:mutation:model-to-matter": "EP_MUTATE_SRC=1 stryker run stryker.model-to-matter.config.js",
    "release:verify:reproducible": "node scripts/verify-reproducible-package.mjs packages/verify",
    "release:verify:python": "node scripts/verify-reproducible-wheel.mjs packages/python-verify sdks/python integrations/langchain-emilia packages/crewai packages/ep-verify-py",
    "check:release-chain": "node scripts/check-release-chain.mjs",
    "test:consumption-faults": "node --test packages/gate/store-faults.test.js packages/gate/store-postgres.test.js packages/gate/store-linearizability.test.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "setup": "npm install && cp .env.example .env.local 2>/dev/null || true && echo 'Setup complete. Edit .env.local with your credentials.'",
    "prepare": "husky",
    "conformance": "node conformance/run.mjs",
    "caid:conformance": "node caid/conformance/run.mjs",
    "m2m:conformance": "node conformance/run-model-to-matter.mjs",
    "mobile:conformance": "node mobile/conformance/run.mjs",
    "mobile:release-check": "node scripts/check-mobile-release.mjs",
    "mobile:production-readiness": "node scripts/check-mobile-production.mjs",
    "mobile:db-contract": "bash scripts/test-mobile-migration.sh",
    "mobile:regulator-demo": "node examples/regulatory-mobile-oversight/demo.mjs",
    "mobile:live-demo": "node scripts/mobile-live-demo.mjs",
    "mobile:ios-showcase": "bash scripts/mobile-ios-showcase.sh",
    "conformance:manifest": "node scripts/generate-conformance-manifest.mjs --emit conformance/conformance-manifest.json",
    "conformance:manifest:check": "node scripts/generate-conformance-manifest.mjs --check",
    "conformance:manifest:clean-room": "node scripts/check-frozen-clean-room.mjs",
    "conformance:manifest:clean-room:check": "node scripts/check-frozen-clean-room.mjs",
    "conformance:hostility": "node scripts/differential-hostility.mjs",
    "check:public-conformance-claims": "node scripts/check-public-conformance-claims.mjs",
    "check:proof-stats": "node scripts/generate-proof-stats.mjs --check",
    "sync:proof-stats": "node scripts/generate-proof-stats.mjs",
    "check:llm-context": "node scripts/generate-llm-context.mjs --check",
    "sync:llm-context": "node scripts/generate-llm-context.mjs --write",
    "observatory:import-recon": "node scripts/import-standards-recon.mjs",
    "observatory:refresh-sources": "node scripts/refresh-standards-observatory.mjs",
    "observatory:sync": "node scripts/build-standards-observatory.mjs --write",
    "observatory:check": "node scripts/build-standards-observatory.mjs --check",
    "conformance:external:evaluate": "node scripts/evaluate-external-implementation.mjs",
    "conformance:clean-room:selftest": "node scripts/check-frozen-clean-room.mjs && node scripts/test-clean-room-intake.mjs",
    "conformance:clean-room:contract": "node scripts/test-clean-room-intake.mjs",
    "conformance:clean-room:kit": "node scripts/build-clean-room-kit.mjs",
    "conformance:signoffs": "node conformance/run-signoffs.mjs",
    "conformance:federation": "node conformance/federation.mjs",
    "conformance:operator2": "node conformance/operator2/verify-live.mjs"
  },
  "lint-staged": {
    "{app,components}/**/*.{js,mjs,ts,tsx}": [
      "eslint --max-warnings=0"
    ],
    "lib/**/*.{ts,tsx,mts}": [
      "eslint --max-warnings=0"
    ],
    "{app,lib,components}/**/*.{js,mjs,ts,tsx,mts}": [
      "node scripts/check-license-headers.js"
    ]
  },
  "dependencies": {
    "@emilia-protocol/require-receipt": "file:packages/require-receipt",
    "@emilia-protocol/verify": "file:packages/verify",
    "@noble/curves": "2.2.0",
    "@noble/post-quantum": "^0.6.1",
    "@node-saml/node-saml": "^5.1.0",
    "@remotion/player": "^4.0.489",
    "@sentry/nextjs": "10.65.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.2",
    "@supabase/supabase-js": "^2.110.5",
    "cbor": "10.0.12",
    "cbor-x": "^1.6.4",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "mammoth": "^1.12.0",
    "mcp-handler": "^1.1.0",
    "motion": "^12.42.2",
    "next": "15.5.21",
    "node-app-attest": "1.0.1",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "remotion": "^4.0.452",
    "stripe": "^22.3.1",
    "viem": "^2.55.2",
    "xlsx": "https://cdn.sheetjs.com/xlsx-0.20.3/xlsx-0.20.3.tgz",
    "zod": "^4.4.3"
  },
  "overrides": {
    "@hono/node-server": "2.0.10",
    "body-parser": "2.3.0",
    "fast-uri": "3.1.4",
    "hono": "4.12.27",
    "rollup": "^4.22.5",
    "postcss": "^8.5.12",
    "qs": "^6.15.2",
    "sharp": "0.35.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^9.39.5",
    "eslint-config-next": "^16.2.9",
    "fast-check": "^4.9.0",
    "husky": "^9.0.0",
    "lint-staged": "^17.0.8",
    "pako": "3.0.1",
    "pg": "^8.22.0",
    "qrcode": "1.5.4",
    "typescript": "^5.9.3",
    "tsx": "^4.19.3",
    "vitest": "^4.1.0",
    "yaml": "2.9.0"
  }
}
