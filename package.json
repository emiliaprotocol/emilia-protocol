{
  "name": "emilia-protocol",
  "version": "1.0.0",
  "description": "EMILIA Protocol — Trust enforcement for high-risk actions. Open protocol for pre-action binding, policy-bound verification, one-time consumption, and accountable human signoff.",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:run": "vitest run",
    "check:protocol": "node scripts/check-protocol-discipline.js",
    "reconstitute": "node scripts/replay-protocol.js --reconstitute",
    "test:mutation": "stryker run",
    "setup": "npm install && cp .env.example .env.local 2>/dev/null || true && echo 'Setup complete. Edit .env.local with your credentials.'",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,mjs,ts,tsx}": [
      "eslint --max-warnings=0",
      "node scripts/check-license-headers.js"
    ]
  },
  "dependencies": {
    "@remotion/player": "^4.0.441",
    "@sentry/nextjs": "^8.0.0",
    "@supabase/supabase-js": "^2.45.0",
    "next": "^15.5.14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.441",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.0.0",
    "@stryker-mutator/core": "^8.0.0",
    "@stryker-mutator/vitest-runner": "^8.0.0",
    "fast-check": "^4.6.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "pg": "^8.20.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
