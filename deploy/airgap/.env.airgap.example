# EMILIA Protocol — air-gap environment template.
# Copy to .env.airgap on the isolated host and fill in. NEVER commit the filled
# copy. install.sh refuses to run with the placeholder values below.

# Postgres (bundled, in-cluster — not reachable off-host)
POSTGRES_USER=ep
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password
POSTGRES_DB=emilia

# Supabase self-host secrets. Generate on a connected machine:
#   SUPABASE_JWT_SECRET   : openssl rand -hex 32   (the PostgREST JWT secret)
#   SUPABASE_SERVICE_ROLE_KEY / SUPABASE_ANON_KEY : JWTs signed with that secret
#     (role=service_role / role=anon). See README.md "Generate keys".
SUPABASE_JWT_SECRET=CHANGE_ME_openssl_rand_hex_32
SUPABASE_SERVICE_ROLE_KEY=CHANGE_ME_service_role_jwt
SUPABASE_ANON_KEY=CHANGE_ME_anon_jwt
