{
  "name": "@emilia-protocol/mcp-server",
  "mcpName": "io.github.emiliaprotocol/mcp-server",
  "version": "1.1.1",
  "description": "Stop your AI agent before it does something irreversible. ep_guard_action holds a payment, deletion, or account change until a named human signs off \u2014 and returns a receipt anyone can verify offline. The seatbelt for agent tool calls, over MCP.",
  "main": "bundle.js",
  "type": "module",
  "bin": {
    "emilia-mcp": "./bundle.js"
  },
  "files": [
    "bundle.js",
    "auto-receipt.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "node scripts/build-bundle.mjs",
    "prepack": "npm run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@emilia-protocol/verify": "^3.10.1"
  },
  "overrides": {
    "@hono/node-server": "2.0.10",
    "body-parser": "2.3.0",
    "fast-uri": "3.1.4",
    "hono": "4.12.27"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "esbuild": "^0.28.1",
    "vitest": "^4.1.8"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "human-in-the-loop",
    "human-signoff",
    "webauthn",
    "passkey",
    "irreversible-actions",
    "payment-guard",
    "agent-accountability",
    "agent-safety",
    "ai-agents",
    "trust-receipt",
    "offline-verification",
    "separation-of-duties",
    "policy-evaluation",
    "delegation",
    "emilia-protocol"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/emiliaprotocol/emilia-protocol.git"
  },
  "homepage": "https://emiliaprotocol.ai",
  "bugs": {
    "url": "https://github.com/emiliaprotocol/emilia-protocol/issues"
  }
}
