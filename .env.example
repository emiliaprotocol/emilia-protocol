# Supabase
# Required: EP expects a Supabase-compatible HTTP API.
# A raw Postgres container alone is not sufficient.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key          # Must be NEXT_PUBLIC_ for browser client

# OpenAI (for entity embeddings + semantic search)
OPENAI_API_KEY=sk-your-openai-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# EP API (used by CLI, MCP server, and SDKs)
EP_BASE_URL=https://emiliaprotocol.ai
EP_API_KEY=ep_live_your-api-key

# Cron authentication (for /api/blockchain/anchor and dispute resolution)
CRON_SECRET=your-cron-secret-hex

# Base L2 blockchain anchoring (optional — Merkle roots published on-chain)
BASE_RPC_URL=https://mainnet.base.org
EP_WALLET_PRIVATE_KEY=your-private-key
BASE_WALLET_ADDRESS=0xYourWalletAddress
EP_ANCHOR_CONTRACT=                          # Leave empty for data-only tx to self
BASE_NETWORK=mainnet                         # or: sepolia

# Upstash Redis (optional — for rate limiting and receipt deduplication)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# GitHub (optional — for adapter-based trust lookups)
GITHUB_TOKEN=ghp_your-github-token

# Sentry error reporting (optional — disabled when blank)
SENTRY_DSN=                                  # Server-side DSN (never exposed to browser)
NEXT_PUBLIC_SENTRY_DSN=                      # Browser-side DSN (public, safe to expose)
SENTRY_ORG=                                  # Sentry organization slug (for source maps)
SENTRY_PROJECT=emilia-protocol              # Sentry project slug
SENTRY_ENVIRONMENT=production               # production | staging | development

# Commit signing (cryptographic integrity of issued commits)
EP_COMMIT_SIGNING_KEY=                       # Active HMAC signing key (hex, 32+ bytes)
EP_COMMIT_SIGNING_KEYS=                      # Comma-separated list of valid keys (for rotation)

# Auto-submit (server-to-server receipt pipeline)
EP_AUTO_SUBMIT_SECRET=                       # HMAC secret for /api/receipts/auto-submit

# MCP auto-receipt (optional — enables automatic receipt capture by the MCP server)
EP_AUTO_RECEIPT_OPT_IN=false                 # Set to 'true' to enable MCP auto-receipting
EP_AUTO_RECEIPT_URL=                         # EP endpoint for auto-receipt submission
EP_AUTO_RECEIPT_ENTITY_ID=                   # Entity ID to record as the MCP actor
EP_AUTO_RECEIPT_KEY=                         # API key for auto-receipt requests
EP_AUTO_RECEIPT_DEBUG=false                  # Set to 'true' to enable verbose MCP receipt logging
