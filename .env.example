# Supabase
# Required: EP expects a Supabase-compatible HTTP API.
# A raw Postgres container alone is not sufficient.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key          # Must be NEXT_PUBLIC_ for browser client

# OpenAI (for entity embeddings + semantic search)
OPENAI_API_KEY=sk-your-openai-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# EP API (used by CLI, MCP server, and SDKs)
EP_BASE_URL=https://emiliaprotocol.ai
EP_API_KEY=ep_live_your-api-key

# Rx appeal-bundle privacy projection (required only when appeal_bundle=true)
EP_RX_PRIVACY_KEY_B64U=                       # Base64url of >=32 random bytes; separate from signing keys
EP_RX_PRIVACY_KEY_ID=rx-privacy-2026-01      # Non-secret rotation identifier carried in projected bundles

# Cron authentication (for /api/blockchain/anchor and dispute resolution)
CRON_SECRET=your-cron-secret-hex

# Base L2 blockchain anchoring (optional — Merkle roots published on-chain)
BASE_RPC_URL=https://mainnet.base.org
EP_WALLET_PRIVATE_KEY=your-private-key
BASE_WALLET_ADDRESS=0xYourWalletAddress
EP_ANCHOR_CONTRACT=                          # Leave empty for data-only tx to self
BASE_NETWORK=mainnet                         # or: sepolia
EP_BLOCKCHAIN_SIGNING_MODE=env              # env | kms | hsm; external modes require a registered custody provider
EP_BLOCKCHAIN_SIGNING_KEY_ID=               # required when mode is kms or hsm

# Upstash Redis (optional — for rate limiting and receipt deduplication)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# GitHub (optional — for adapter-based trust lookups)
GITHUB_TOKEN=ghp_your-github-token

# Sentry error reporting (optional — disabled when blank)
SENTRY_DSN=                                  # Server-side DSN (never exposed to browser)
NEXT_PUBLIC_SENTRY_DSN=                      # Browser-side DSN (public, safe to expose)
SENTRY_ORG=                                  # Sentry organization slug (for source maps)
SENTRY_PROJECT=emilia-protocol              # Sentry project slug
SENTRY_ENVIRONMENT=production               # production | staging | development

# Commit signing (cryptographic integrity of issued commits)
EP_COMMIT_SIGNING_KEY=                       # Active Ed25519 seed (base64, 32 bytes)
EP_COMMIT_SIGNING_KEYS=                      # JSON map of kid -> public key (for rotation)

# Public crash-test demo signing (never used for production authorizations)
EP_DEMO_SIGNING_KEY=                         # Required for dynamic demo receipts in production; base64 32-byte Ed25519 seed

# Government / high-assurance posture
EP_GOV_STRICT=false                          # explicit opt-in mode (gov/high-assurance pilots). NOT auto-on in production — the public instance stays a permissive dev playground.
EP_TRUSTED_ISSUER_KEYS=                      # Comma-separated or JSON array of base64url SPKI issuer keys
EP_PINNED_APPROVER_KEYS=                     # JSON object keyed by approver_key_id: {"ep:key:cfo#1":{"public_key":"<b64url-SPKI-DER-ed25519>","key_class":"B"}}. Verifies class_a/quorum receipts on /api/v1/guarded. UNSET => those tiers FAIL CLOSED (software tier still passes). key_class "A" => WebAuthn, else Ed25519. Quorum distinctness keys on the map's approver_key_id, so one entry per real human approver.
EP_WEBAUTHN_RP_ID=www.emiliaprotocol.ai      # Required for strict Class-A WebAuthn verification
EP_EXPECTED_POLICY_HASH=                     # Optional pinned policy hash for strict offline verification
EP_SECRET_KEY=                               # 64 hex chars (32 bytes) for AES-GCM sealing stored secrets; required in production
EP_KEY_CUSTODY_MODE=local-dev                # local-dev | kms | hsm (kms/hsm required for gov/prod)
EP_KMS_KEY_ID=                               # Required when EP_KEY_CUSTODY_MODE=kms
EP_HSM_KEY_ID=                               # Required when EP_KEY_CUSTODY_MODE=hsm
EP_FIPS_REQUIRED=false                       # Records whether the deployment requires FIPS-validated modules
EP_AUDIT_HOT_DAYS=365                        # Hot audit retention target
EP_AUDIT_COLD_DAYS=2190                      # Cold audit retention target (6 years)
EP_AUDIT_EXPORT_ENABLED=false                # true when audit export to agency/SIEM is configured
EP_REQUIRE_DURABLE_RATE_LIMIT=false          # true forces write/admin limits to fail closed unless Upstash is configured
EP_TIER_QUORUM_ENFORCE=true                  # Default ON (fail-closed): a 'dual' value-tier receipt (e.g. payment >= $1M) requires 2 distinct Class-A approvers to consume. Set to 'false' only to explicitly opt out (permissive dev/demo posture).
WEBAUTHN_RP_ID=emiliaprotocol.ai             # Registrable RP domain used by Release Lock and browser approval ceremonies
WEBAUTHN_ORIGIN=https://www.emiliaprotocol.ai # Exact browser origin that performs the approval ceremony

# Release Lock (two-party change-order acceptance and exact draw release)
RELEASE_LOCK_TOKEN_HMAC_KEY=                 # >=32 random bytes; hashes invitation, session, and pairing bearer tokens
RELEASE_LOCK_CONTACT_HMAC_KEY=               # >=32 random bytes; binds verified contact identifiers without storing them in evidence
RELEASE_LOCK_AUTHORITY_KEYS_JSON=             # Pinned provider Ed25519 keys: {"provider":{"key-id":{"algorithm":"Ed25519","public_key":"<base64url SPKI DER>"}}}
RELEASE_LOCK_PUBLIC_ORIGIN=https://www.emiliaprotocol.ai
RELEASE_LOCK_INVITATION_FROM=                # Verified Resend sender, for example Release Lock <lock@example.com>
RELEASE_LOCK_ACROBAT_SIGN_API_ORIGIN=        # Pinned Acrobat Sign API origin returned for the deployment account
RELEASE_LOCK_ACROBAT_SIGN_OAUTH_ACCESS_TOKEN= # Server-only OAuth access token; rotate before provider expiry
RELEASE_LOCK_ESCROW_COM_ENVIRONMENT=sandbox  # sandbox | production; must exactly match the signed draw
RELEASE_LOCK_ESCROW_COM_EMAIL=                # Server-only Escrow.com API credential email
RELEASE_LOCK_ESCROW_COM_API_KEY=              # Server-only Escrow.com API key
RELEASE_LOCK_ESCROW_COM_DILIGENCE_JSON=       # Non-secret JSON recording the customer's completed provider/licensing review

# Native EMILIA Approver (iOS + Android)
MOBILE_IOS_BUNDLE_ID=ai.emiliaprotocol.approver
MOBILE_ANDROID_PACKAGE_NAME=ai.emiliaprotocol.approver
MOBILE_APPLE_TEAM_ID=5M2Z48UQQY
MOBILE_PROFILE_ID=emilia.high-assurance.mobile.v1
MOBILE_RP_ID=www.emiliaprotocol.ai
MOBILE_IOS_ORIGIN=https://www.emiliaprotocol.ai
MOBILE_APPLE_ALLOWED_VALIDATION_CATEGORIES=2,4 # TestFlight and App Store; set 3 only for development verification
MOBILE_APPLE_ALLOWED_BUNDLE_VERSIONS=1       # CFBundleVersion values accepted from signed App Attest runtime signals
MOBILE_APPLE_REQUIRE_RUNTIME_SIGNALS=false   # Set true only when the deployment requires iOS 27+ runtime extensions
MOBILE_ANDROID_APK_KEY_HASHES=               # Comma-separated unpadded base64url SHA-256 hashes used in android:apk-key-hash origins
MOBILE_ANDROID_CERTIFICATE_DIGESTS=          # Comma-separated Play response certificateSha256Digest values
MOBILE_ANDROID_ASSETLINKS_CERT_SHA256=       # Comma-separated uppercase colon-delimited SHA-256 signing fingerprints
MOBILE_ANDROID_ALLOWED_VERSION_CODES=1       # Play-distributed versionCode values accepted by the high-assurance profile
MOBILE_ANDROID_MIN_SDK_VERSION=33            # Android 13+ makes MEETS_STRONG_INTEGRITY include recent security updates
MOBILE_ANDROID_REQUIRE_PLAY_PROTECT=true     # Requires Play Protect NO_ISSUES and the Play Console optional verdict
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=            # Raw or base64-encoded service-account JSON with Play Integrity access; server only
MOBILE_PLAY_ATTESTATION_KEY_ID=play-integrity:production
MOBILE_CHALLENGE_TTL_MS=300000
MOBILE_PAIRING_TTL_MS=600000
MOBILE_SESSION_TTL_MS=2592000000
MOBILE_DEMO_ENABLED=false                      # Explicitly enable the authenticated demo-action injector only in a demo environment

# Auto-submit (server-to-server receipt pipeline)
EP_AUTO_SUBMIT_SECRET=                       # HMAC secret for /api/receipts/auto-submit

# MCP auto-receipt (optional — enables automatic receipt capture by the MCP server)
EP_AUTO_RECEIPT_OPT_IN=false                 # Set to 'true' to enable MCP auto-receipting
EP_AUTO_RECEIPT_URL=                         # EP endpoint for auto-receipt submission
EP_AUTO_RECEIPT_ENTITY_ID=                   # Entity ID to record as the MCP actor
EP_AUTO_RECEIPT_KEY=                         # API key for auto-receipt requests
EP_AUTO_RECEIPT_DEBUG=false                  # Set to 'true' to enable verbose MCP receipt logging

# Stripe — EP Cloud billing (see docs/STRIPE_SETUP.md). Run scripts/stripe-setup.mjs
# with your ROTATED secret key to create products/prices/links, then set these.
STRIPE_SECRET_KEY=                           # SECRET — set in Vercel only, never commit. Embedded checkout (/api/checkout)
STRIPE_PRICE_CLOUD_TEAM=                     # price_... (Team plan)
STRIPE_PRICE_CLOUD_BUSINESS=                 # price_... (Business plan)
NEXT_PUBLIC_STRIPE_CLOUD_TEAM=               # https://buy.stripe.com/... public payment link (Team)
NEXT_PUBLIC_STRIPE_CLOUD_BUSINESS=           # https://buy.stripe.com/... public payment link (Business)
