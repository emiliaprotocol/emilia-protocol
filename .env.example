# Supabase
# Required: EP expects a Supabase-compatible HTTP API.
# A raw Postgres container alone is not sufficient.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# OpenAI (for entity embeddings + semantic search)
OPENAI_API_KEY=sk-your-openai-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# EP API (used by CLI, MCP server, and SDKs)
EP_API_URL=https://emiliaprotocol.ai
EP_BASE_URL=https://emiliaprotocol.ai
EP_API_KEY=ep_live_your-api-key

# Cron authentication (for /api/blockchain/anchor and dispute resolution)
CRON_SECRET=your-cron-secret-hex

# Base L2 blockchain anchoring (optional — Merkle roots published on-chain)
BASE_RPC_URL=https://mainnet.base.org
EP_WALLET_PRIVATE_KEY=your-private-key
BASE_WALLET_ADDRESS=0xYourWalletAddress
EP_ANCHOR_CONTRACT=                          # Leave empty for data-only tx to self
BASE_NETWORK=mainnet                         # or: sepolia

# Upstash Redis (optional — for rate limiting and receipt deduplication)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# GitHub (optional — for adapter-based trust lookups)
GITHUB_TOKEN=ghp_your-github-token
