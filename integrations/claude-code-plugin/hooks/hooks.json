        "matcher": "Bash|Write|Edit|MultiEdit|mcp__.*",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${CLAUDE_PLUGIN_ROOT}/hooks/guard.mjs\"",
            "timeout": 600
          }
        ]
      }
    ]
  }
}
