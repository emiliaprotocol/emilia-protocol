ARG NODE_IMAGE=node:22.23.1-alpine3.24@sha256:16e22a550f3863206a3f701448c45f7912c6896a62de43add43bb9c86130c3e2

FROM ${NODE_IMAGE} AS dependencies

WORKDIR /opt/consequence-control

COPY packages/gate packages/gate
COPY packages/require-receipt packages/require-receipt
COPY packages/verify packages/verify
COPY apps/consequence-control-service apps/consequence-control-service

RUN npm ci --prefix apps/consequence-control-service --ignore-scripts --omit=dev \
    && npm cache clean --force

FROM ${NODE_IMAGE} AS runtime

ENV NODE_ENV=production \
    HOST=0.0.0.0 \
    PORT=8080 \
    EMILIA_CONSEQUENCE_CONFIG=/app/apps/consequence-control-service/src/production-config.js

WORKDIR /app

COPY packages/gate packages/gate
COPY packages/require-receipt packages/require-receipt
COPY packages/verify packages/verify
COPY caid caid
COPY apps/gate-service apps/gate-service
COPY --from=dependencies /opt/consequence-control/apps/consequence-control-service/node_modules apps/consequence-control-service/node_modules
COPY apps/consequence-control-service/package.json apps/consequence-control-service/package.json
COPY apps/consequence-control-service/src apps/consequence-control-service/src
COPY apps/consequence-control-service/test apps/consequence-control-service/test

RUN ln -s /app/apps/consequence-control-service/node_modules /app/node_modules \
    && rm -rf /usr/local/lib/node_modules/npm \
              /usr/local/lib/node_modules/corepack \
              /opt/yarn-v1.22.22 \
    && rm -f /usr/local/bin/npm \
             /usr/local/bin/npx \
             /usr/local/bin/corepack \
             /usr/local/bin/yarn \
             /usr/local/bin/yarnpkg

USER node
EXPOSE 8080

CMD ["node", "apps/consequence-control-service/src/server.js"]
