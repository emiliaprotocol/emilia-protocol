{
  "name": "@emilia-protocol/sdk",
  "version": "0.1.0",
  "description": "Reference TypeScript SDK for trust profiles, policy evaluation, install preflight, disputes, and appeals across counterparties, software, and machine actors.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "prepare": "npm run clean && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "trust",
    "trust-profile",
    "policy-evaluation",
    "install-preflight",
    "appeals",
    "disputes",
    "software-trust",
    "marketplace-trust",
    "counterparties",
    "machine-actors",
    "mcp",
    "emilia-protocol"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/emiliaprotocol/emilia-protocol"
  },
  "homepage": "https://emiliaprotocol.ai",
  "bugs": {
    "url": "https://github.com/emiliaprotocol/emilia-protocol/issues"
  },
  "devDependencies": {
    "typescript": "^5.6.3"
  }
}
