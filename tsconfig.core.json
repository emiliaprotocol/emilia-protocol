{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "strictNullChecks": true,
    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "skipLibCheck": true,
    "noImplicitAny": false,
    "resolveJsonModule": true
  },
  "include": [
    "packages/verify/**/*.js",
    "packages/gate/**/*.ts",
    "lib/handshake/**/*.js",
    "lib/handshake/**/*.ts",
    "packages/gate/**/*.js"
  ],
  "exclude": [
    "**/*.test.js",
    "packages/verify/dist/**",
    "packages/gate/dist/**",
    "**/node_modules/**",
    "**/*.test.ts",
    "**/*.test.mts"
  ]
}
